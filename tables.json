{
  "v_demand": {
    "description": "V版生产需求表(Vendor/Customer Demand)，记录原始市场预测。时间粒度为月、每周一版。横向表。",
    "columns": [
      "id",
      "PM_VERSION (版本号)",
      "FGCODE (生产需求号)",
      "SBU_DESC (SBU描述)",
      "CUSTOMER (客户)",
      "MONTH (需求起始月份)",
      "REQUIREMENT_QTY (需求起始月份 需求数量)",
      "NEXT_REQUIREMENT (需求起始月份第2个月 需求数量)",
      "LAST_REQUIREMENT (需求起始月份第3个月 需求数量)",
      "MONTH4 (需求起始月份第4个月 需求数量)",
      "MONTH5 (需求起始月份第5个月 需求数量)",
      "MONTH6 (需求起始月份第6个月 需求数量)",
      "MONTH7 (需求起始月份第7个月 需求数量)"
    ],
    "MAIN_KEY": "PM_VERSION,FGCODE,SBU_DESC,CUSTOMER",
    "month_col": "MONTH",
    "version_col": "PM_VERSION",
    "relationships": {}
  },
