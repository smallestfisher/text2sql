  "daily_inventory": {
    "description": "每日库存快照表，记录各仓库各产品的可用库存、Hold库存。时间粒度为日。",
    "columns": [
      "id",
      "report_date (上报日期)",
      "factory_code (工厂代码)",
      "ERP_FACTORY (ERP工厂)",
      "ERP_LOCATION (ERP库位)",
      "product_ID (产品型号)",
      "PRODUCTION_TYPE (产品类型)",
      "GRADE (产品等级)",
      "CHECKINCODE (产品Check In Code)",
      "TTL_Qty (TTL库存量)",
      "HOLD_Qty (Hold库存量)"
    ],
    "MAIN_KEY": "report_date,factory_code,ERP_FACTORY,ERP_LOCATION,product_ID,PRODUCTION_TYPE,GRADE,CHECKINCODE",
    "date_col": "report_date",
    "relationships": {
      "product_ID": "product_attributes.product_ID"
    }
  },
  "daily_PLAN": {
    "description": "每日排产计划表，记录各工厂各产品的投入目标产量。时间粒度为日。",
