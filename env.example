# =========================
# 应用基础配置
# =========================
# 应用名称，只影响文档和接口展示。
APP_NAME="Text2SQL Backend"
# 应用版本号。
APP_VERSION="0.3.0"
# 运行环境标识，常见值如 dev / test / prod。
APP_ENV="dev"
# 日志级别，常见值：DEBUG / INFO / WARNING / ERROR。
LOG_LEVEL="INFO"
# 是否开启 FastAPI 的 docs / redoc / openapi。
ENABLE_DOCS="true"
# 是否开启闲聊模式。
# false：非业务问题直接判为 terminal non-SQL 响应
# true：仅对带有 chitchat 权限的用户返回简短闲聊回复，但仍不会进入 SQL 链路
ENABLE_CHITCHAT_MODE="false"

# =========================
# 业务数据库
# =========================
# 主业务库连接串。
BUSINESS_DATABASE_URL="mysql+pymysql://user:password@127.0.0.1:3306/your_business_db"

# =========================
# Runtime 数据库
# =========================
# runtime 库用于保存会话、trace、query log、SQL audit、feedback 等运行时数据。
# 如果不显式配置，系统会基于 BUSINESS_DATABASE_URL 自动派生，并使用 RUNTIME_DATABASE_NAME。
# RUNTIME_DATABASE_URL="mysql+pymysql://user:password@127.0.0.1:3306/manager"
# 自动派生 runtime 库时使用的数据库名。
RUNTIME_DATABASE_NAME="manager"

# =========================
# 主 LLM 配置
# =========================
# 主推理模型 API Key。
OPENAI_API_KEY="your_llm_api_key"
# 主推理模型 API Base。
OPENAI_API_BASE="https://api.siliconflow.cn/v1"
# 主推理模型名称。
LLM_MODEL="Qwen/Qwen3-14B"
# 单次 LLM 请求超时秒数。
LLM_TIMEOUT_SECONDS="20"
# LLM 调用失败后的最大重试次数。
LLM_MAX_RETRIES="2"
# SQL validator 或 execution 失败后，允许 LLM repair 的最大次数。
SQL_REPAIR_MAX_RETRIES="1"

# =========================
# 向量检索配置
# =========================
# 可选值通常包括：siliconflow / openai / compatible / local / disabled
VECTOR_RETRIEVAL_PROVIDER="siliconflow"
# 向量服务 API Key；如果不单独配置，会默认复用 OPENAI_API_KEY。
VECTOR_API_KEY="your_vector_api_key"
# 向量服务 API Base；如果不单独配置，会默认复用 OPENAI_API_BASE。
VECTOR_API_BASE="https://api.siliconflow.cn/v1"
# 向量模型名称。
VECTOR_MODEL="Qwen/Qwen3-Embedding-8B"
# 向量维度。要和所选 embedding 模型输出保持一致。
VECTOR_DIMENSIONS="1024"
# 向量召回 top_k。
VECTOR_TOP_K="3"
# 向量请求超时秒数。
VECTOR_TIMEOUT_SECONDS="20"

# =========================
# SQL / 执行治理
# =========================
# 数据库会话级 SQL 超时秒数。
SQL_TIMEOUT_SECONDS="30"
# 默认 SQL LIMIT。
DEFAULT_SQL_LIMIT="200"
# 高风险场景允许的最大 LIMIT。
HIGH_RISK_SQL_LIMIT="1000"
# 单次返回结果的最大行数，超过会被截断。
EXECUTION_MAX_ROWS="500"
# 慢查询阈值，单位毫秒。
SLOW_QUERY_THRESHOLD_MS="3000"

# =========================
# 执行结果缓存
# =========================
# 相同 SQL 的执行结果缓存 TTL，单位秒。
EXECUTION_CACHE_TTL_SECONDS="30"
# 执行缓存最多保留多少条。
EXECUTION_CACHE_MAX_ENTRIES="256"

# =========================
# 鉴权配置
# =========================
# JWT / token 签名密钥，生产环境必须替换。
AUTH_TOKEN_SECRET="change-me"
# 登录 token 过期时间，单位秒。默认 28800 = 8 小时。
AUTH_TOKEN_TTL_SECONDS="28800"
