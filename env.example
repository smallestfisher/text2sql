# Core app
APP_NAME="Text2SQL Backend"
APP_VERSION="0.3.0"
APP_ENV="dev"
LOG_LEVEL="INFO"
ENABLE_DOCS="true"

# Business database
# Prefer BUSINESS_DATABASE_URL. DB_URI is kept for backward compatibility.
BUSINESS_DATABASE_URL="mysql+pymysql://user:password@127.0.0.1:3306/your_business_db"
# DB_URI="mysql+pymysql://user:password@127.0.0.1:3306/your_business_db"

# Runtime database
# Optional. If omitted, the app derives it from the business database URL
# and uses RUNTIME_DATABASE_NAME.
# RUNTIME_DATABASE_URL="mysql+pymysql://user:password@127.0.0.1:3306/manager"
RUNTIME_DATABASE_NAME="manager"

# LLM
OPENAI_API_KEY="your_llm_api_key"
OPENAI_API_BASE="https://api.siliconflow.cn/v1"
LLM_MODEL="Qwen/Qwen3-14B"
LLM_TIMEOUT_SECONDS="20"
LLM_MAX_RETRIES="2"
SQL_REPAIR_MAX_RETRIES="1"

# Vector retrieval
VECTOR_RETRIEVAL_PROVIDER="siliconflow"
VECTOR_API_KEY="your_vector_api_key"
VECTOR_API_BASE="https://api.siliconflow.cn/v1"
VECTOR_MODEL="Qwen/Qwen3-Embedding-8B"
VECTOR_DIMENSIONS="1024"
VECTOR_TOP_K="3"
VECTOR_TIMEOUT_SECONDS="20"

# SQL / execution
SQL_TIMEOUT_SECONDS="30"
DEFAULT_SQL_LIMIT="200"
HIGH_RISK_SQL_LIMIT="1000"
EXECUTION_MAX_ROWS="500"
SLOW_QUERY_THRESHOLD_MS="3000"

# Execution cache
EXECUTION_CACHE_TTL_SECONDS="30"
EXECUTION_CACHE_MAX_ENTRIES="256"

# Auth
AUTH_TOKEN_SECRET="change-me"
AUTH_TOKEN_TTL_SECONDS="28800"
