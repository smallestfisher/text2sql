{
  "query_profiles": {
    "inventory": {
      "allowed_fields": [
        "source_table",
        "biz_date",
        "biz_month",
        "factory_code",
        "ERP_FACTORY",
        "ERP_LOCATION",
        "product_ID",
        "application",
        "common_categories",
