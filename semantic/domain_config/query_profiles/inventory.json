        {
          "entities": [
            "erp_factory"
          ],
          "exclude_filter_fields": [
            "ERP_FACTORY"
          ],
          "add_dimensions": [
            "ERP_FACTORY"
          ]
        },
        {
          "entities": [
            "stage_product"
          ],
          "exclude_filter_fields": [
            "product_ID"
          ],
          "add_dimensions": [
            "product_ID"
          ]
        },
        {
          "entities": [
            "customer"
          ],
          "exclude_filter_fields": [
            "customer"
          ],
          "add_dimensions": [
            "customer"
          ]
        },
        {
          "time_grain": "day",
          "exclude_filter_fields": [
