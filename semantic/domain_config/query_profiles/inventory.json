          "exclude_filter_fields": [
            "factory_code",
            "ERP_FACTORY"
          ],
          "reason_code": "inventory_factory_ambiguous",
          "question_type": "clarification_needed",
          "reason": "库存域中的工厂语义不明确。",
          "clarification_question": "库存查询请明确使用 factory_code 还是 ERP_FACTORY。"
        }
