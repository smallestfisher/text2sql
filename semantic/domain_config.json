{
  "version": "0.1.0",
  "domains": [
    {
      "name": "demand",
      "tables": ["v_demand", "p_demand", "sales_financial_perf"],
      "primary_entities": ["fg_product", "customer"]
    },
    {
      "name": "sales_financial",
      "tables": ["sales_financial_perf"],
      "primary_entities": ["fg_product", "customer"]
    },
    {
      "name": "inventory",
      "tables": ["daily_inventory", "oms_inventory"],
      "primary_entities": ["stage_product"]
    },
    {
      "name": "plan_actual",
      "tables": ["daily_PLAN", "monthly_plan_approved", "weekly_rolling_plan", "production_actuals"],
      "primary_entities": ["stage_product", "factory", "plan_time"]
    },
    {
      "name": "dimension",
      "tables": ["product_attributes", "product_mapping"],
      "primary_entities": ["stage_product", "fg_product"]
    }
  ],
  "entities": [
    {
      "name": "fg_product",
      "aliases": ["FGCODE", "成品型号", "成品编码", "需求型号", "销售型号"],
      "description": "成品阶段产品实体，主要用于需求和销售财务分析。"
    },
    {
      "name": "stage_product",
      "aliases": ["product_ID", "型号", "产品型号", "产品编码"],
      "description": "生产阶段产品实体，存在 Cell/Array/CF 等阶段编码。"
    },
    {
      "name": "factory",
      "aliases": ["factory", "FACTORY", "工厂"],
      "description": "计划/实际等生产域中的工厂概念。"
    },
    {
      "name": "factory_code",
      "aliases": ["factory_code", "工厂代码"],
      "description": "库存域中的工厂代码字段。"
    },
    {
      "name": "erp_factory",
      "aliases": ["ERP_FACTORY", "erp_factory", "ERP工厂"],
      "description": "ERP 体系下的工厂字段。"
    },
    {
      "name": "customer",
      "aliases": ["CUSTOMER", "客户"],
      "description": "客户实体。"
    },
    {
      "name": "plan_time",
      "aliases": ["日期", "月份", "周版本", "计划日期", "结算月份", "版本"],
      "description": "时间和版本相关实体，用于承载日、月、周版本和计划版本语义。"
    }
  ],
  "time_semantics": [
    {
      "name": "day_level",
      "tables": ["daily_inventory", "daily_PLAN", "production_actuals", "weekly_rolling_plan", "monthly_plan_approved"],
      "fields": ["report_date", "PLAN_date", "work_date", "plan_date"],
      "description": "日粒度查询。"
    },
    {
      "name": "month_level",
      "tables": ["v_demand", "p_demand", "oms_inventory", "sales_financial_perf", "monthly_plan_approved"],
      "fields": ["MONTH", "report_month", "plan_month"],
      "description": "月粒度查询。"
    },
    {
      "name": "versioned",
      "tables": ["v_demand", "p_demand", "weekly_rolling_plan"],
      "fields": ["PM_VERSION"],
      "description": "带版本语义的查询对象。"
    }
  ],
  "question_understanding": {
    "invalid_exact_patterns": ["你好", "hello", "hi", "谢谢", "thanks"],
    "follow_up_cues": ["只看", "换成", "那", "再看", "改成", "分别", "继续", "然后"],
    "context_management": {
      "replace_filter_groups": {
        "time": ["biz_date", "biz_month"],
        "version": ["PM_VERSION"]
      }
    },
    "classification": {
      "rules": [
        {
          "name": "unknown_domain_follow_up",
          "question_type": "follow_up",
          "subject_domain": "session_subject_domain",
          "inherit_context": true,
          "confidence": 0.84,
          "reason": "当前问题缺少完整主体，但明显在延续上一轮查询。",
          "when": {
            "session_required": true,
            "subject_domain_in": ["unknown"],
            "any_signals": ["has_follow_up_cue", "has_explicit_slots"]
          }
        },
        {
          "name": "same_domain_follow_up",
          "question_type": "follow_up",
          "subject_domain": "parse_subject_domain",
          "inherit_context": true,
          "confidence": 0.88,
          "reason": "当前问题延续了上一轮主题，仅变更指标、过滤或粒度。",
          "when": {
            "session_required": true,
            "subject_domain_equals_session": true,
            "any_signals": [
              "has_follow_up_cue",
              "missing_metrics",
              "new_filter_fields",
              "reused_filter_fields",
              "time_grain_changed",
              "version_changed"
            ]
          }
        },
        {
          "name": "same_domain_new_related",
          "question_type": "new_related",
          "subject_domain": "parse_subject_domain",
          "inherit_context": false,
          "confidence": 0.8,
          "reason": "当前问题与上一轮属于同一主题域，但可独立执行。",
          "when": {
            "session_required": true,
            "subject_domain_equals_session": true
          }
        },
        {
          "name": "implicit_filter_follow_up",
          "question_type": "follow_up",
          "subject_domain": "session_subject_domain",
          "inherit_context": true,
          "confidence": 0.82,
          "reason": "当前问题只是在补充过滤、时间或版本条件，应继承上一轮主题。",
          "when": {
            "session_required": true,
            "all_signals": [
              "missing_metrics"
            ],
            "any_signals": [
              "has_follow_up_cue",
              "new_filter_fields",
              "reused_filter_fields",
              "time_grain_changed",
              "version_changed"
            ]
          }
        },
        {
          "name": "different_domain_new_unrelated",
          "question_type": "new_unrelated",
          "subject_domain": "parse_subject_domain",
          "inherit_context": false,
          "confidence": 0.9,
          "reason": "当前问题切换到了新的业务主题域，不应继承上一轮上下文。",
          "when": {
            "session_required": true,
            "subject_domain_known": true,
            "domain_changed": true
          }
        }
      ]
    },
    "clarification_questions": {
      "unknown_request": "请补充你要查询的主题、指标和时间范围，例如库存、计划投入或实际产出。",
      "missing_metric": "请补充要查询的指标，例如库存量、计划投入量、实际产出或销售业绩。",
      "fallback": "请补充查询目标、时间范围或统计口径。"
    }
  },
  "domain_inference": {
    "metric_to_domain": {
      "inventory_qty": "inventory",
      "plan_input_qty": "plan_actual",
      "actual_output_qty": "plan_actual",
      "actual_input_qty": "plan_actual",
      "demand_qty": "demand",
      "sales_qty": "sales_financial",
      "financial_qty": "sales_financial"
    },
    "hints": [
      {
        "domain": "inventory",
        "entities": ["factory_code", "erp_factory"],
        "filter_fields": ["factory_code", "ERP_FACTORY", "ERP_LOCATION", "product_ID"]
      },
      {
        "domain": "plan_actual",
        "entities": ["factory"],
        "filter_fields": ["factory", "stage_product_id"],
        "keywords": ["计划", "实际", "产出", "投入"]
      },
      {
        "domain": "demand",
        "entities": ["fg_product", "customer"],
        "filter_fields": ["FGCODE", "customer", "PM_VERSION"]
      },
      {
        "domain": "sales_financial",
        "filter_fields": ["sales_qty", "financial_qty"]
      }
    ],
    "fallback_to_session": true
  },
  "extractors": {
    "time": [
      {
        "name": "cn_day",
        "type": "calendar_day",
        "field": "biz_date",
        "pattern": "(\\d{4})年(\\d{1,2})月(\\d{1,2})日"
      },
      {
        "name": "iso_day",
        "type": "iso_day",
        "field": "biz_date",
        "pattern": "(\\d{4}-\\d{2}-\\d{2})"
      },
      {
        "name": "cn_month",
        "type": "calendar_month",
        "field": "biz_month",
        "pattern": "(\\d{4})年(\\d{1,2})月(?!\\d)"
      },
      {
        "name": "compact_month",
        "type": "compact_month",
        "field": "biz_month",
        "pattern": "\\b(20\\d{2}(?:0[1-9]|1[0-2]))\\b"
      }
    ],
    "filters": [
      {
        "name": "factory_keyword",
        "type": "keyword_enum",
        "field": "factory",
        "op": "=",
        "candidates": ["CELL", "ARRAY", "CF"],
        "flags": ["uppercase"]
      },
      {
        "name": "factory_code_pattern",
        "type": "regex",
        "field": "factory_code",
        "op": "=",
        "pattern": "\\b([A-Z]\\d+_[A-Z]+)\\b",
        "flags": ["uppercase"]
      },
      {
        "name": "erp_factory_explicit",
        "type": "regex",
        "field": "ERP_FACTORY",
        "op": "=",
        "pattern": "(?:ERP_FACTORY|ERP工厂)\\s*[:：]?\\s*([A-Za-z0-9._-]+)",
        "flags": ["ignorecase"]
      },
      {
        "name": "erp_location_explicit",
        "type": "regex",
        "field": "ERP_LOCATION",
        "op": "=",
        "pattern": "(?:ERP_LOCATION|ERP库位|库位)\\s*[:：]?\\s*([A-Za-z0-9._-]+)",
        "flags": ["ignorecase"]
      },
      {
        "name": "stage_product_explicit",
        "type": "regex",
        "field": "product_ID",
        "op": "=",
        "pattern": "(?:product_ID|型号|产品型号|产品编码)\\s*[:：]?\\s*([A-Za-z0-9._/-]+)",
        "flags": ["ignorecase"]
      },
      {
        "name": "fgcode_explicit",
        "type": "regex",
        "field": "FGCODE",
        "op": "=",
        "pattern": "(?:FGCODE|成品型号|成品编码|需求型号|销售型号)\\s*[:：]?\\s*([A-Za-z0-9._/-]+)",
        "flags": ["ignorecase"]
      },
      {
        "name": "customer_explicit",
        "type": "regex",
        "field": "customer",
        "op": "=",
        "pattern": "(?:CUSTOMER|customer|客户)\\s*(?:[:：=]|为|是)\\s*([A-Za-z0-9._\\-\\u4e00-\\u9fa5]+)",
        "flags": ["ignorecase"]
      },
      {
        "name": "demand_month_compact",
        "type": "regex",
        "field": "demand_month",
        "op": "=",
        "pattern": "\\b(20\\d{2}(?:0[1-9]|1[0-2]))\\b(?=\\s*需求)",
        "flags": ["ignorecase"]
      },
      {
        "name": "demand_source_p",
        "type": "regex",
        "field": "source_table",
        "op": "=",
        "pattern": "(?:^|[^A-Za-z0-9])P版(?:[^A-Za-z0-9]|$)",
        "value": "p_demand",
        "flags": ["ignorecase"]
      },
      {
        "name": "demand_source_v",
        "type": "regex",
        "field": "source_table",
        "op": "=",
        "pattern": "(?:^|[^A-Za-z0-9])V版(?:[^A-Za-z0-9]|$)",
        "value": "v_demand",
        "flags": ["ignorecase"]
      }
    ],
    "dimensions": [
      {
        "name": "group_by_customer",
        "type": "regex",
        "field": "customer",
        "pattern": "(?:按|按照|只看)\\s*(?:CUSTOMER|customer|客户)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_factory_code",
        "type": "regex",
        "field": "factory_code",
        "pattern": "(?:按|按照|只看)\\s*factory_code(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_factory",
        "type": "regex",
        "field": "factory",
        "pattern": "(?:按|按照|只看)\\s*(?:FACTORY|factory|工厂)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_erp_factory",
        "type": "regex",
        "field": "ERP_FACTORY",
        "pattern": "(?:按|按照|只看)\\s*(?:ERP_FACTORY|ERP工厂)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_stage_product",
        "type": "regex",
        "field": "product_ID",
        "pattern": "(?:按|按照|只看)\\s*(?:product_ID|型号|产品型号|产品编码)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_fgcode",
        "type": "regex",
        "field": "FGCODE",
        "pattern": "(?:按|按照|只看)\\s*(?:FGCODE|成品型号|成品编码|需求型号|销售型号)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_date",
        "type": "regex",
        "field": "biz_date",
        "pattern": "(?:按|按照|只看)\\s*(?:日|天|日期)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_month",
        "type": "regex",
        "field": "biz_month",
        "pattern": "(?:按|按照|只看)\\s*(?:月|月份)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      },
      {
        "name": "group_by_version",
        "type": "regex",
        "field": "PM_VERSION",
        "pattern": "(?:按|按照|只看)\\s*(?:版本|PM_VERSION)(?:维度)?(?:拆分|分组|查看|统计|看)?",
        "flags": ["ignorecase"]
      }
    ],
    "version": [
      {
        "field": "PM_VERSION",
        "pattern": "(?:版本|version|PM_VERSION)\\s*[:：]?\\s*([A-Za-z0-9._-]+)",
        "flags": ["ignorecase"]
      },
      {
        "field": "PM_VERSION",
        "pattern": "([A-Za-z0-9._-]+)\\s*(?:版本|version)",
        "flags": ["ignorecase"]
      },
      {
        "field": "PM_VERSION",
        "pattern": "最新\\s*(\\d{1,2})\\s*版",
        "value_template": "LATEST_N:{match}",
        "flags": ["ignorecase"]
      }
    ],
    "analysis": [
      {
        "mode": "trend",
        "pattern": "趋势|走势|变化趋势",
        "flags": ["ignorecase"]
      },
      {
        "mode": "compare",
        "pattern": "对比|比较|对照",
        "flags": ["ignorecase"]
      }
    ],
    "sort": [
      {
        "field": "sales_qty",
        "order": "desc",
        "pattern": "(?:按|依)?销售(?:业绩|量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "financial_qty",
        "order": "desc",
        "pattern": "(?:按|依)?财务(?:业绩|量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "inventory_qty",
        "order": "desc",
        "pattern": "(?:按|依)?库存(?:量|数量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "demand_qty",
        "order": "desc",
        "pattern": "(?:按|依)?需求(?:量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "demand_qty",
        "order": "desc",
        "pattern": "(?:需求最多|最多的(?:fgcode|成品型号)|需求最高|最高需求)",
        "flags": ["ignorecase"]
      },
      {
        "field": "actual_output_qty",
        "order": "desc",
        "pattern": "(?:按|依)?实际产出(?:量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "plan_input_qty",
        "order": "desc",
        "pattern": "(?:按|依)?计划投入(?:量)?(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "customer",
        "order": "desc",
        "pattern": "(?:按|依)?客户(?:从高到低|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "biz_month",
        "order": "desc",
        "pattern": "(?:按|依)?月份?(?:从新到旧|降序|倒序)",
        "flags": ["ignorecase"]
      },
      {
        "field": "biz_date",
        "order": "desc",
        "pattern": "(?:按|依)?日期(?:从新到旧|降序|倒序)",
        "flags": ["ignorecase"]
      }
    ],
    "limit": [
      {
        "pattern": "(?:前|top\\s*)(\\d{1,3})(?:条|个|名)?",
        "flags": ["ignorecase"]
      },
      {
        "pattern": "(?:哪一个|哪个)",
        "value": 1,
        "flags": ["ignorecase"]
      }
    ]
  },
  "metrics": [
    {
      "name": "inventory_qty",
      "aliases": ["库存", "库存量", "库存数量"],
      "semantic_column": "inventory_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "daily_inventory",
          "expression": "sum(TTL_Qty)",
          "grain": "day"
        },
        {
          "table": "oms_inventory",
          "expression": "sum(panel_qty)",
          "grain": "month"
        }
      ]
    },
    {
      "name": "plan_input_qty",
      "aliases": ["计划投入", "投入量", "计划投入量"],
      "semantic_column": "plan_input_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "daily_PLAN",
          "expression": "sum(target_qty)",
          "grain": "day"
        },
        {
          "table": "monthly_plan_approved",
          "expression": "sum(target_IN_glass_qty)",
          "grain": "month_or_day"
        }
      ]
    },
    {
      "name": "actual_output_qty",
      "aliases": ["实际产出", "产出量"],
      "semantic_column": "actual_output_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "production_actuals",
          "expression": "sum(Panel_qty)",
          "grain": "day"
        }
      ]
    },
    {
      "name": "actual_input_qty",
      "aliases": ["实际投入", "实际投产"],
      "semantic_column": "actual_input_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "production_actuals",
          "expression": "sum(GLS_qty)",
          "grain": "day"
        }
      ]
    },
    {
      "name": "demand_qty",
      "aliases": ["需求", "需求量", "V版需求", "P版需求"],
      "semantic_column": "demand_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "v_demand",
          "expression": "normalized_from_horizontal_month_columns",
          "grain": "month"
        },
        {
          "table": "p_demand",
          "expression": "normalized_from_horizontal_month_columns",
          "grain": "month"
        }
      ]
    },
    {
      "name": "sales_qty",
      "aliases": ["销售业绩", "销售量"],
      "semantic_column": "sales_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "sales_financial_perf",
          "expression": "sum(sales_qty)",
          "grain": "month"
        }
      ]
    },
    {
      "name": "financial_qty",
      "aliases": ["财务业绩", "财务量"],
      "semantic_column": "financial_qty",
      "aggregate_function": "SUM",
      "definitions": [
        {
          "table": "sales_financial_perf",
          "expression": "sum(FINANCIAL_qty)",
          "grain": "month"
        }
      ]
    }
  ],
  "query_profiles": {
    "inventory": {
      "allowed_fields": [
        "source_table",
        "biz_date",
        "biz_month",
        "factory_code",
        "ERP_FACTORY",
        "ERP_LOCATION",
        "product_ID",
        "application",
        "common_categories",
        "GRADE",
        "inventory_qty",
        "hold_qty",
        "customer",
        "sbu_desc",
        "bu_desc"
      ],
      "field_aliases": {
        "biz_date": ["report_date"],
        "biz_month": ["report_month"],
        "customer": ["CUSTOMER"],
        "sbu_desc": ["SBU_DESC"],
        "bu_desc": ["BU_DESC"],
        "inventory_qty": ["TTL_Qty", "panel_qty"],
        "hold_qty": ["HOLD_Qty"]
      },
      "default_limit": 200,
      "max_limit": 200,
      "time_filter_fields": ["biz_date", "biz_month"],
      "warn_if_missing_time_filter": true,
      "table_selection": {
        "prefer_metric_tables": true,
        "fallback_to_domain_tables": true
      },
      "default_sort": [
        {
          "field": "biz_date",
          "order": "desc"
        }
      ],
      "permission_scope_fields": {
        "factories": "factory_code",
        "customers": "customer",
        "products": "product_ID"
      },
      "dimension_preferences": [
        {
          "entities": ["factory_code"],
          "exclude_filter_fields": ["factory_code"],
          "add_dimensions": ["factory_code"]
        },
        {
          "entities": ["erp_factory"],
          "exclude_filter_fields": ["ERP_FACTORY"],
          "add_dimensions": ["ERP_FACTORY"]
        },
        {
          "entities": ["stage_product"],
          "exclude_filter_fields": ["product_ID"],
          "add_dimensions": ["product_ID"]
        },
        {
          "entities": ["customer"],
          "exclude_filter_fields": ["customer"],
          "add_dimensions": ["customer"]
        },
        {
          "time_grain": "day",
          "exclude_filter_fields": ["biz_date"],
          "add_dimensions": ["biz_date"]
        }
      ],
      "clarification_rules": [
