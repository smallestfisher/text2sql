{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "query_plan.schema.json",
  "title": "Text2SQL Query Plan Schema",
  "description": "Compiled query plan produced by the planner/compiler from a QueryDraft. This is the final structured representation before SQL generation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "entity", "source", "select_fields", "from_clause"],
  "properties": {
    "plan_id": {
      "type": "string",
      "description": "Unique identifier for this query plan"
    },
    "entity": {
      "type": "string",
      "description": "Primary semantic entity, e.g. Demand.V"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table_or_view", "alias"],
      "properties": {
        "table_or_view": {
          "type": "string",
          "description": "Physical table or semantic view name"
        },
        "alias": {
          "type": "string"
        }
      }
    },
    "select_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/selectField" },
      "description": "All columns in the SELECT clause"
    },
    "from_clause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base"],
      "properties": {
        "base": {
          "type": "object",
          "additionalProperties": false,
          "required": ["table", "alias"],
          "properties": {
            "table": { "type": "string" },
            "alias": { "type": "string" }
          }
        },
        "joins": {
          "type": "array",
          "items": { "$ref": "#/$defs/joinClause" }
        }
      }
    },
    "where_conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/whereCondition" },
      "description": "All WHERE clause conditions"
    },
    "group_by": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Physical field references for GROUP BY"
    },
    "having_conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/whereCondition" }
    },
    "order_by": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "direction"],
        "properties": {
          "field": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["ASC", "DESC"]
          }
        }
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "field_sources": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["user_explicit", "clarification_confirmed", "system_default", "planner_inferred", "context_inherited"]
      },
      "description": "Map of each field/filter to its origin source, for context inheritance decisions"
    },
    "defaults_applied": {
      "type": "object",
      "additionalProperties": {},
      "description": "Map of field name to the default value that was applied by the compiler"
    },
    "join_graph_edges_used": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of join_graph relation IDs used in this plan, for audit and validation"
    },
    "join_template_used": {
      "type": "string",
      "description": "ID of the join template from join_graph.yaml, if applicable"
    },
    "aggregation_strategy": {
      "type": "string",
      "enum": ["aggregate_then_join", "join_then_aggregate", "no_aggregation"],
      "description": "Whether the plan aggregates before joining or after"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Non-fatal warnings from the compiler, e.g. large result set, implicit defaults"
    },
    "explanation": {
      "type": "string",
      "description": "Human-readable summary of what this query plan does, for user-facing口径说明"
    }
  },
  "$defs": {
    "selectField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias", "expr", "role"],
      "properties": {
        "alias": {
          "type": "string",
          "description": "Output column name"
        },
        "expr": {
          "type": "string",
          "description": "SQL expression, e.g. SUM(d.demand_qty) or pa.application"
        },
        "role": {
          "type": "string",
          "enum": ["metric", "dimension", "filter_echo"],
          "description": "Whether this field is a metric (aggregated), dimension (grouped), or echoed filter value"
        },
        "semantic_name": {
          "type": "string",
          "description": "Semantic model field name for traceability"
        },
        "source_entity": {
          "type": "string",
          "description": "Which entity this field comes from"
        }
      }
    },
    "joinClause": {
      "type": "object",
      "additionalProperties": false,
      "required": ["join_type", "table", "alias", "on"],
      "properties": {
        "join_type": {
          "type": "string",
          "enum": ["LEFT JOIN", "INNER JOIN"]
        },
        "table": {
          "type": "string"
        },
        "alias": {
          "type": "string"
        },
        "on": {
          "type": "string",
          "description": "JOIN ON condition"
        },
        "join_graph_relation_id": {
          "type": "string",
          "description": "Reference to the join_graph.yaml relation ID that authorized this join"
        }
      }
    },
    "whereCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "op", "value"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Physical field reference, e.g. d.demand_month"
        },
        "op": {
          "type": "string",
          "enum": ["=", "!=", ">", ">=", "<", "<=", "IN", "NOT IN", "BETWEEN", "LIKE"]
        },
        "value": {
          "description": "Single value, array (for IN/BETWEEN), or string pattern (for LIKE)"
        },
        "source": {
          "type": "string",
          "enum": ["user_explicit", "clarification_confirmed", "system_default", "planner_inferred", "context_inherited"],
          "description": "Where this filter condition originated"
        }
      }
    }
  }
}
